# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

ARG VITE_RPC_URL=https://rpc-zk.tanenbaum.io
ARG VITE_CHAIN_ID=57057
ARG VITE_EXPLORER_URL=https://explorer-zk.tanenbaum.io
ARG VITE_CONTRACT_EVIDENCE_REGISTRY=
ARG VITE_CONTRACT_CASE_MANAGER=
ARG VITE_CONTRACT_DID_REGISTRY=
ARG VITE_CONTRACT_EVIDENCE_SEAL=
ARG VITE_CONTRACT_TOKEN=
ARG VITE_API_URL=http://localhost:8001

ENV VITE_RPC_URL=$VITE_RPC_URL
ENV VITE_CHAIN_ID=$VITE_CHAIN_ID
ENV VITE_EXPLORER_URL=$VITE_EXPLORER_URL
ENV VITE_CONTRACT_EVIDENCE_REGISTRY=$VITE_CONTRACT_EVIDENCE_REGISTRY
ENV VITE_CONTRACT_CASE_MANAGER=$VITE_CONTRACT_CASE_MANAGER
ENV VITE_CONTRACT_DID_REGISTRY=$VITE_CONTRACT_DID_REGISTRY
ENV VITE_CONTRACT_EVIDENCE_SEAL=$VITE_CONTRACT_EVIDENCE_SEAL
ENV VITE_CONTRACT_TOKEN=$VITE_CONTRACT_TOKEN
ENV VITE_API_URL=$VITE_API_URL

COPY package*.json ./
RUN npm install

COPY . .
RUN npm run build

# Production stage with Nginx
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
