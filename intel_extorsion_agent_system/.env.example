# IntelExtorsión Agent System - Variables de Entorno

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# GroqCloud
GROQ_API_KEY=gsk-your-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2
GROQ_MAX_TOKENS=4096

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=intel_extorsion
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=agent_pass
# DATABASE_URL=postgresql+asyncpg://agent_user:agent_pass@localhost:5432/intel_extorsion

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_DENUNCIAS=denuncias_embeddings
QDRANT_DIMENSION=384

# Redis
REDIS_URL=redis://localhost:6379/0

# Agentes
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=120
OSINT_ENABLED=true
OSINT_MAX_REQUESTS_PER_MINUTE=30

# Alertas
ALERT_WEBHOOK_URL=
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_FROM=
