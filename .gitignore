# =============================================================================
# INTEL EXTORSIÓN - .gitignore
# =============================================================================
# Este archivo ignora archivos que NO deben subirse a GitHub:
# - Dependencias instaladas (node_modules, __pycache__)
# - Variables de entorno con secrets (.env, .env.local)
# - Builds y archivos generados
# - Volúmenes y datos de bases de datos locales
# =============================================================================

# =============================================================================
# 1. ARCHIVOS DE ENTORNO (NUNCA subir secrets)
# =============================================================================
.env 
.env.local
.env.*.local
.env.development
.env.test
.env.production
!.env.example
!.env.template
*.pem
*.key

# =============================================================================
# 2. NODE.JS / NEXT.JS / REACT
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Next.js build output
.next/
out/
dist/
build/
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel

# =============================================================================
# 3. PYTHON / FASTAPI
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv/
.env.bak/

# Pytest / Coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/

# Jupyter Notebook
.ipynb_checkpoints

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# =============================================================================
# 4. HARDHAT / SOLIDITY / BLOCKCHAIN
# =============================================================================
# Hardhat build artifacts
artifacts/
cache/
typechain/
typechain-types/

# Ignorar compilaciones de contratos generadas
*.dbg.json

# Ignorar deployments locales (guardar solo scripts de deploy)
# Si necesitas guardar addresses de deploy en testnet, usa un archivo JSON 
# versionado separado, no la carpeta completa de deployments
deployments/localhost/

# Gas reporter
gas-report.txt

# Coverage de Solidity
coverage/
coverage.json
lcov.info

# =============================================================================
# 5. DOCKER
# =============================================================================
# Volúmenes de datos locales (¡IMPORTANTE! No subir bases de datos)
volumes/
postgres_data/
redis_data/
qdrant_data/

# Imágenes y layers
docker-compose.override.yml
*.tar

# =============================================================================
# 6. BASES DE DATOS LOCALES
# =============================================================================
*.sqlite
*.sqlite3
*.db
*.db-journal
pgdata/
mongodb_data/

# =============================================================================
# 7. LOGS
# =============================================================================
logs/
*.log
log/

# =============================================================================
# 8. IDEs y EDITORES
# =============================================================================
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# JetBrains (WebStorm, PyCharm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
\.\#*

# =============================================================================
# 9. SISTEMA OPERATIVO
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp

# Linux
.directory
.Trash-*

# =============================================================================
# 10. ARCHIVOS TEMPORALES Y BACKUPS
# =============================================================================
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
*.rej

# =============================================================================
# 11. ARCHIVOS DE MULTIMEDIA / EVIDENCIA (Opcional)
# Si quieres ignorar audios/videos subidos en desarrollo local:
# uploads/
# evidence/
# media/
# =============================================================================

# =============================================================================
# 12. ARCHIVOS ESPECÍFICOS DEL PROYECTO
# =============================================================================
# Modelos descargados localmente por fastembed (si se usan fuera de Docker)
models/
*.onnx

# Archivos de test de integración que generan outputs
test-output/
test-results/

# =============================================================================
# EXCEPCIONES (No ignorar estos)
# =============================================================================
# Asegurarse de que los archivos importantes NO sean ignorados
!README.md
!AGENTS.md
!INSTALL.md
!RUN.md
!MIGRATION_REPORT.md
!QA_REPORT.md
!API_KEYS_GUIDE.md
!CHECKLIST_DEPLOY.md
